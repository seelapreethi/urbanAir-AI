# --- BACKEND ENVIRONMENT VARIABLES ---
ENVIRONMENT=development
JWT_SECRET=supersecretjwtsecretkeychangeinproduction123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL Database Configuration
# In docker-compose, postgres hostname is 'db'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urbanair

# Redis Cache Configuration
REDIS_URL=redis://localhost:6379/0

# AI Configuration
OPENROUTER_API_KEY=your-openrouter-free-api-key
VECTOR_DB_PATH=./app/ai/vector_store

# --- FRONTEND ENVIRONMENT VARIABLES ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_APP_NAME=UrbanAir AI
